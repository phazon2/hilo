# Copy this file to .env and fill in your key. Never commit .env.
#
# Key comes from Alibaba Cloud Model Studio, SINGAPORE console:
#   modelstudio.console.alibabacloud.com/ap-southeast-1  ->  API-KEY  ->  Create
# (Never the Beijing console bailian.console.* — its keys do not work internationally.)

DASHSCOPE_API_KEY=sk-your-key-here

# Any chat model visible in your Model Studio catalog.
# If this one fails, `python test_connection.py` tries fallbacks and prints the line to put here.
QWEN_MODEL=qwen-turbo

# International (Singapore) OpenAI-compatible endpoint. Do not change unless Alibaba does.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
